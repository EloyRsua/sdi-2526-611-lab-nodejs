{% extends "layout.twig" %}

{% block title %} Detalles de canción {% endblock %}

{% block main_container %}
	<div class="row">
		<div class="media col-xs-10">
			<div class="media-left media-middle">
				<img class="media-object" src="/covers/{{ song._id }}.png">
			</div>
			<div class="media-body">
				<h2>{{ song.title }}</h2>
				<p>{{ song.author }}</p>
				<p>{{ song.kind }}</p>
				<p><strong>{{ song.price }} €</strong></p>

				{% if canListen %}
					{# El usuario es autor o ya compró la canción: mostrar reproductor #}
					<audio controls>
						<source src="/audios/{{ song._id }}.mp3" type="audio/mpeg">
					</audio>
				{% else %}
					{# El usuario puede comprar la canción #}
					<form method="post" action="/songs/buy/{{ song._id }}">
						<button type="submit" class="btn btn-success">Comprar {{ song.price }} €- {{ song.usd }} $<</button>
					</form>
				{% endif %}
			</div>
		</div>
	</div>

	<h3>Comentarios</h3>
	<div class="table-responsive">
		<table class="table table-hover">
			<thead>
			<tr>
				<th>Autor</th>
				<th>Comentario</th>
				<th class="col-md-1"></th>
			</tr>
			</thead>
			<tbody>
			{% for comment in comments %}
				<tr>
					<td>{{ comment.author }}</td>
					<td>{{ comment.text }}</td>
					<td><a href="/comments/delete/{{ comment._id }}">Borrar</a></td>
				</tr>
			{% endfor %}
			</tbody>
		</table>
	</div>

	<h3>Añadir comentario</h3>
	<form class="form-horizontal" method="post" action="/comments/{{ song._id }}">
		<div class="form-group">
			<label class="control-label col-sm-2" for="text">Comentario:</label>
			<div class="col-sm-10">
				<textarea id="text" class="form-control" name="text" rows="3"
						  placeholder="Escribe tu comentario..." required></textarea>
			</div>
		</div>
		<div class="form-group">
			<div class="col-sm-offset-2 col-sm-10">
				<button type="submit" class="btn btn-primary">Enviar</button>
			</div>
		</div>
	</form>
{% endblock %}
